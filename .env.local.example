# 阿里云百炼 (DashScope) API Key
# 获取方式：https://bailian.console.aliyun.com/?apiKey=1
DASHSCOPE_API_KEY=sk-xxx

# 指定模型
# 可选值: qwen-turbo / qwen-plus / qwen-max / qwen3-...
DASHSCOPE_MODEL=qwen-plus

# Supabase Postgres
# 把 [YOUR-PASSWORD] 替换成 Supabase 项目的 Database password。
# 如果密码里有 @ / : / ? / # 等特殊字符，请使用 URL encode 后的密码。
DATABASE_URL="postgresql://postgres.cdfshxeqpdatsrwcsoos:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.cdfshxeqpdatsrwcsoos:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js / GitHub OAuth
# 生成方式：npx auth secret
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_GITHUB_ID="replace-with-github-oauth-client-id"
AUTH_GITHUB_SECRET="replace-with-github-oauth-client-secret"

# 开发阶段升级口令。只在服务端读取，不要加 NEXT_PUBLIC_ 前缀。
PRO_UPGRADE_CODE="replace-with-pro-upgrade-code"
ADMIN_UPGRADE_CODE="replace-with-admin-upgrade-code"
