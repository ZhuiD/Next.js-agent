generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  plan          String       @default("free") // "free" | "pro" | "admin"
  accounts      Account[]
  sessions      Session[]
  chats         Chat[]
  rateLimit     RateLimit?
  quotaUsages   QuotaUsage[]
  agentRuns     AgentRun[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Chat {
  id        String     @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([userId, updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String
  partsJson String?
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

// 每个用户一条记录，记录当前时间窗口内的请求次数
// 用于实现"每小时最多 N 次"的滑动窗口限流
model RateLimit {
  userId      String   @id
  count       Int      @default(0)
  windowStart DateTime // 当前计数窗口的起始时间

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum QuotaUsageStatus {
  RESERVED
  CONSUMED
  REFUNDED
}

// RateLimit 是当前窗口的快速计数快照；QuotaUsage 是每次请求的可审计流水。
// chatId 不设外键：额度在 Chat 创建前就要预占，而且删除聊天记录不应抹掉历史账目。
model QuotaUsage {
  id            String           @id @default(cuid())
  userId        String
  requestId     String           @unique // 用户消息 id，作为同一次请求的幂等键
  chatId        String?
  plan          String
  amount        Int              @default(1)
  limit         Int
  status        QuotaUsageStatus @default(RESERVED)
  windowStart   DateTime
  consumeReason String?
  refundReason  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  consumedAt    DateTime?
  refundedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
  ABORTED
}

// 一次用户请求对应一个 AgentRun；具体过程拆成按 sequence 排序的 AgentEvent。
// requestMessageId 用于关联用户触发这次运行的消息，也能阻止同一消息重复建 run。
model AgentRun {
  id                String         @id @default(cuid())
  userId            String
  chatId            String
  requestMessageId  String         @unique
  responseMessageId String?
  status            AgentRunStatus @default(RUNNING)
  nextSequence      Int            @default(0)
  errorMessage      String?
  startedAt         DateTime       @default(now())
  finishedAt        DateTime?
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat              Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  events            AgentEvent[]

  @@index([userId, startedAt])
  @@index([chatId, startedAt])
  @@index([status, startedAt])
}

// type/scope/name 使用字符串而不是数据库 enum：可观测事件会随 Agent 能力扩展，
// 新增一种公开事件不应该每次都要求修改数据库枚举。
model AgentEvent {
  id         String   @id @default(cuid())
  runId      String
  sequence   Int
  type       String
  scope      String
  name       String?
  status     String
  title      String
  detail     String?
  durationMs Int?
  createdAt  DateTime @default(now())
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId, createdAt])
}
