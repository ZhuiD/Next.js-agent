# Optional local database for running pnpm test:integration on your own machine.
# GitHub Actions creates its own disposable Postgres service automatically.
# Never point this at your development or production Supabase database.
#
# Local setup:
# 1. Copy this file to .env.test.
# 2. Create a local disposable Postgres database named codex_test.
# 3. Apply migrations to that database before running integration tests.

TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codex_test?sslmode=disable"

# This must be explicit because integration tests wipe all rows before each test.
ALLOW_TEST_DATABASE_RESET="true"
