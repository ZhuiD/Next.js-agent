{
  "name": "git-trend-insight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "node scripts/test-database.mjs check && vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:quality": "pnpm lint && pnpm generate && pnpm typecheck && pnpm test:unit && pnpm build",
    "test:ci": "pnpm test:quality",
    "db:test:migrate": "node scripts/test-database.mjs migrate"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.49",
    "@ai-sdk/react": "^3.0.204",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.202",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "next": "^15.5.18",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "9.0.1",
    "remark-gfm": "^4.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.19",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "postcss": "^8.5.14",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "5.8.3",
    "vitest": "^4.1.10"
  }
}
